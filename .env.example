# OAuth token signing secret — generate with: openssl rand -hex 32
MCP_OAUTH_TOKEN_SECRET=

# Upstash Redis REST credentials (required in production)
UPSTASH_REDIS_REST_URL=https://<your-database>.upstash.io
UPSTASH_REDIS_REST_TOKEN=

# Comma-separated API keys for MCP client authentication
MCP_API_KEYS=

# Optional overrides
# MUSASHI_API_BASE_URL=https://musashi-api.vercel.app
# PORT=3000
